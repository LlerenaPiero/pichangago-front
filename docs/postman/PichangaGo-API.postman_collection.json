{
  "info": {
    "name": "PichangaGo API",
    "description": "Colección completa de endpoints para PichangaGo.\n\nFlujo típico:\n1. Pide un token con POST /api/login (usuario: ana@test.com, clave: Clave@123)\n2. La colección guarda automáticamente el token en la variable {{token}}\n3. El resto de endpoints lo usan en el header Authorization\n\nAntes de empezar, configura:\n- Variable {{baseUrl}} → http://localhost:5000 (o la URL de tu backend)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Registrar usuario",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Carlos\",\n  \"apellido\": \"López\",\n  \"email\": \"carlos@test.com\",\n  \"password\": \"Clave@123\",\n  \"rol\": \"jugador\",\n  \"telefono\": \"999888777\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "register"]
            }
          }
        },
        {
          "name": "Iniciar sesión (jugador)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "  pm.collectionVariables.set('userId', json.usuario?._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jugador@test.com\",\n  \"password\": \"Clave@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "login"]
            }
          }
        },
        {
          "name": "Iniciar sesión (dueño)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "  pm.collectionVariables.set('userId', json.usuario?._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"dueno@test.com\",\n  \"password\": \"Clave@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "login"]
            }
          }
        },
        {
          "name": "Cerrar sesión",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "logout"]
            }
          }
        },
        {
          "name": "Refrescar token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.collectionVariables.set('token', json.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "refresh"]
            }
          }
        },
        {
          "name": "Validar sesión",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/validate-session",
              "host": ["{{baseUrl}}"],
              "path": ["api", "validate-session"]
            }
          }
        },
        {
          "name": "Health / Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "status"]
            }
          }
        },
        {
          "name": "Olvidé contraseña",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jugador@test.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "forgot-password"]
            }
          }
        },
        {
          "name": "Resetear contraseña",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"reset-token-ejemplo\",\n  \"newPassword\": \"NuevaClave@456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reset-password"]
            }
          }
        }
      ]
    },
    {
      "name": "⚽ Canchas (Público)",
      "item": [
        {
          "name": "Listar canchas",
          "request": {
            "method": "GET",
