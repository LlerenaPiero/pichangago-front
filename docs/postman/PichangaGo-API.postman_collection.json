            }
          }
        },
        {
          "name": "Reservar cancha",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"canchaId\": \"{{canchaId}}\",\n  \"slotId\": \"{{slotId}}\",\n  \"fecha\": \"{{fecha}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/canchas/reservar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "canchas", "reservar"]
            }
          }
        }
      ]
