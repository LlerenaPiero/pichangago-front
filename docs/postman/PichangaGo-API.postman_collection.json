        },
        {
          "name": "Buscar canchas (filtros)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/canchas?distrito=Miraflores&nombre=&precioMin=0&precioMax=200",
              "host": ["{{baseUrl}}"],
              "path": ["api", "canchas"],
              "query": [
                { "key": "distrito", "value": "Miraflores" },
                { "key": "nombre", "value": "" },
                { "key": "precioMin", "value": "0" },
                { "key": "precioMax", "value": "200" }
