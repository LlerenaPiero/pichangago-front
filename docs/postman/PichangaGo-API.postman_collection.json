            }
          }
        },
        {
          "name": "Slots disponibles",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/canchas/{{canchaId}}/slots?fecha={{fecha}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "canchas", "{{canchaId}}", "slots"],
              "query": [
                { "key": "fecha", "value": "{{fecha}}" }
              ]
            }
          }
        },
        {
          "name": "Ofertas del día",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/canchas/ofertas-hoy",
